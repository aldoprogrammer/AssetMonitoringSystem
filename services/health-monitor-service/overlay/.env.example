APP_NAME="AssetMonitoringSystem Health Monitor Service"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8080/api/v1/health

LOG_CHANNEL=stack
LOG_LEVEL=info

DB_CONNECTION=pgsql
DB_HOST=health-monitor-db
DB_PORT=5432
DB_DATABASE=health_monitor_db
DB_USERNAME=asset_monitoring_system
DB_PASSWORD=asset_monitoring_system

CACHE_STORE=file
SESSION_DRIVER=file
QUEUE_CONNECTION=sync
DEVICE_INACTIVE_AFTER_MINUTES=10

RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=asset_monitoring_system
RABBITMQ_PASSWORD=asset_monitoring_system
RABBITMQ_VHOST=/
RABBITMQ_EXCHANGE=asset_monitoring_system.events
RABBITMQ_QUEUE_PREFIX=health
