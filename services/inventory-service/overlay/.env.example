APP_NAME="AssetMonitoringSystem Inventory Service"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8080/api/v1/inventory

LOG_CHANNEL=stack
LOG_LEVEL=info

DB_CONNECTION=pgsql
DB_HOST=inventory-db
DB_PORT=5432
DB_DATABASE=inventory_db
DB_USERNAME=asset_monitoring_system
DB_PASSWORD=asset_monitoring_system

CACHE_STORE=file
SESSION_DRIVER=file
QUEUE_CONNECTION=sync

RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=asset_monitoring_system
RABBITMQ_PASSWORD=asset_monitoring_system
RABBITMQ_VHOST=/
RABBITMQ_EXCHANGE=asset_monitoring_system.events
RABBITMQ_QUEUE_PREFIX=inventory
